#!/usr/bin/env python3
from pwn import *
from Crypto.Util.strxor import strxor
context.log_level = 'error'

p1 = process("/challenge/dispatcher")

task = p1.recvline().strip().decode().split()[-1]
sleep = b"sleep"

key_bytes = strxor(bytes.fromhex(task), sleep)
key = bytes.hex(key_bytes)


p2 = process("/challenge/worker")

flag = b"flag!"
intro = "TASK: "

enc_flag = strxor(bytes.fromhex(key), flag)
payload = intro + bytes.hex(enc_flag)

p2.sendline(payload.encode())
print(p2.recvall(timeout=1).decode())


