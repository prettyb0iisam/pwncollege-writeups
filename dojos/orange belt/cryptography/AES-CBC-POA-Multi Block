#!/usr/bin/env python3
from pwn import *
from Crypto.Util.strxor import strxor
from Crypto.Util.Padding import unpad
context.log_level = 'error'

p_dispatcher = process(["/challenge/dispatcher", "flag"])
output = p_dispatcher.recvline().strip().decode().split()[-1]
iv = output[:32]
ciphertext = ["None"] * 4
ciphertext[0] = output[32:64]
ciphertext[1] = output[64:96]
ciphertext[2] = output[96:128]
ciphertext[3] = output[128:160]
plaintext = ["None"] * 4

ciphertext_flag = ciphertext[0] + ciphertext[1] + ciphertext[2] + ciphertext[3]

p_worker = process("/challenge/worker")
print("POA SUL CIPHERTEXT: ", ciphertext_flag)
print()
for k in range(4):
    intermediate = ""
    already_crafted = ""
    stringa_padding = ""
    for j in range(16):
        j = j+1
        #OTTENIMENTO DEL BYTE CHE PORTA A UNKNOWN COMMAND!
        for n in range(256):
            garbage = "00" * (16-j)
            byte = f"{n:02x}"
            payload = "TASK: " + garbage + byte + already_crafted + ciphertext[k]
            p_worker.sendline(payload.encode())
            response = p_worker.recvline().strip().decode()
            if response == "Unknown command!":
                break

        #OTTENIMENTO DELL'INTERMEDIATE
        indice = f"{j:02x}"
        intermediate = strxor(bytes.fromhex(byte), bytes.fromhex(indice)).hex() + intermediate

        #COSTRUZIONE PER IL PROSSIMO CICLO
        next_indice = f"{j+1:02x}"
        stringa_padding = next_indice * j
        already_crafted = strxor(bytes.fromhex(intermediate), bytes.fromhex(stringa_padding)).hex()
        print("BYTES TROVATI: [" + str(j) + "/16]", end="\r")
    print()
    print("INTERMEDIATE: ", intermediate)
    if k == 0:
        plaintext[k] = strxor(bytes.fromhex(intermediate), bytes.fromhex(iv))
    else:
        plaintext[k] = strxor(bytes.fromhex(intermediate), bytes.fromhex(ciphertext[k-1]))
    print(f"PLAINTEXT BLOCK {k+1}: ", plaintext[k].decode())
    print()

flag = ""
for k in range(4):
    flag += plaintext[k].decode()
print(unpad(flag.encode(), 16).decode())

