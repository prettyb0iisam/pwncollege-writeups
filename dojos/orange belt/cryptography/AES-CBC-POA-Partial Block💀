#!/usr/bin/env python3
from pwn import *
from Crypto.Util.strxor import strxor
from Crypto.Util.Padding import unpad
context.log_level = 'error'

p_dispatcher = process(["/challenge/dispatcher", "pw"])
output = p_dispatcher.recvline().strip().decode().split()[-1]
iv = output[:32]
ciphertext = output[32:]

p_worker = process("/challenge/worker")
p_worker.recvline().strip()
intermediate = ""
already_crafted = ""
print("Ottenimento dell'INTERMEDIATE del CIPHERTEXT: ", ciphertext)
for j in range(16):
    j = j+1
    #OTTENIMENTO DEL BYTE CHE PORTA A UNKNOWN COMMAND!
    for n in range(256):
        garbage = "00" * (16-j)
        byte = f"{n:02x}"
        payload = "TASK: " + garbage + byte + already_crafted + ciphertext
        p_worker.sendline(payload.encode())
        response = p_worker.recvline().strip().decode()
        if response == "Unknown command!":
            break

    #OTTENIMENTO DELL'INTERMEDIATE
    indice = f"{j:02x}"
    intermediate = strxor(bytes.fromhex(byte), bytes.fromhex(indice)).hex() + intermediate

    #COSTRUZIONE PER IL PROSSIMO CICLO
    next_indice = f"{j+1:02x}"
    stringa_padding = next_indice * j
    already_crafted = strxor(bytes.fromhex(intermediate), bytes.fromhex(stringa_padding)).hex()
    print("BYTES TROVATI: [" + str(j) + "/16]", end="\r")
print()
print("INTERMEDIATE: ", intermediate)
print("IV: ", iv)
password = unpad(strxor(bytes.fromhex(intermediate), bytes.fromhex(iv)), 16)
print("PASSWORD: ", password.decode())
p_redeem = process("/challenge/redeem")
p_redeem.sendline(password)
print(p_redeem.recvall().decode())

## 🧑🏾‍🏫 what this challenge teaches u
POA=Padding Oracle Attack
AES Decryption works in the following way:
-Intermediate=DEC(C) with the key
-XOR between the Intermediate with the IV
One of the flaws that the server can have is the Oracle which it tells u if the padding is correct or no
we can exploit the presence of the Oracle and retrieve the plaintext of the ciphertext even without the key
the steps to retrieve the password by exploiting the Oracle are:
 1-bruteforce the IV[15] byte until u get "Unknown command" -> this means the padding is correct
 2-Xor this byte with the padding -> this byte is the intermediate[15]
 3-setup the correct string for the next byte -> xoring the intermediate with the next padding
 4-repeat the cicle until u get the full Intermediate string
Once u got the Intermediate, just XOR it with the original IV to retrieve the Plaintext
