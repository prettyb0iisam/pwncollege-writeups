from pwn import *
from Crypto.Cipher import AES
import string
import textwrap
context.log_level = 'error'

p = process("/challenge/run")
charset = "}" + string.ascii_letters + string.digits + "{.-_"
flag = ""

for i in range(15):
    for c in charset:
        j = 15 - i
        n = 6 + i
        preappend = format(ord(c), 'x') +  flag + f"{j:02x}" * j 
        padding = "aa" * n

        payload = preappend + padding

        p.sendline(payload.encode())
        p.recvuntil("Ciphertext: ".encode())
        result = textwrap.wrap(p.recvline().decode(), 32)
        block_flag = result[-1]
        block_char = result[0]

        if block_char == block_flag:
            flag = format(ord(c), 'x') + flag
            break
