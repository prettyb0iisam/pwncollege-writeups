#!/usr/bin/env python3
from pwn import *
import string
context.log_level = 'error'

p = process("/challenge/run")
charset = string.ascii_letters + string.digits + "{.-_}"
flag = ""

for i in range(59):
    p.sendline("2".encode())
    p.sendline("0".encode())
    p.sendline(str(i+1).encode())
    p.recvuntil(b"Result: ")
    enc_flag = p.recvline().strip().decode().split()[-1]
    for c in charset:
        payload = flag + c
        p.sendline("1".encode())
        p.sendline(payload.encode())
        p.recvuntil(b"Result: ")
        result = p.recvline().strip().decode().split()[-1]
        if result == enc_flag:
            flag += c
            print(flag, end="\r")
            break
print()

