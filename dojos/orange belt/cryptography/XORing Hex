#!/usr/bin/env python3
from pwn import *
context.log_level = 'error'

p = process("/challenge/run")

p.recvline()

for i in range (10):
    key = int(p.recvline().strip().decode().split()[-1], 16)

    encrypted_secret = int(p.recvline().strip().decode().split()[-1], 16)

    decrypted_secret = key ^ encrypted_secret

    p.sendline(hex(decrypted_secret).encode())
    p.recvline()
    p.recvline()
    p.recvline()
print(p.recvall().decode())

