#!/usr/bin/env python3
from pwn import *
import requests
import string
from bs4 import BeautifulSoup
context.log_level = 'error'

url = "http://challenge.localhost:80/"
headers = {
    "Host" : "challenge.localhost"
}
charset = string.ascii_letters + string.digits + "{-._}"
flag = ""

for i in range(60):
    params1 = {
        "query" : f"SUBSTR(flag,1,{i+1})"
    }
    r1 = requests.get(url, headers=headers, params=params1)
    soup_flag = BeautifulSoup(r1.text, 'html.parser')
    cipher_flag_char = soup_flag.find_all('pre')[-1]

    for c in charset:
        payload = flag + c
        params2 = {
            "query" : f"'{payload}'"
        }
        r2 = requests.get(url, headers=headers, params=params2)
        soup_char = BeautifulSoup(r2.text, 'html.parser')
        result = soup_char.find_all('pre')[-1]
        
        if result == cipher_flag_char:
            flag += c
            print(flag, end="\r")
            break
print()

