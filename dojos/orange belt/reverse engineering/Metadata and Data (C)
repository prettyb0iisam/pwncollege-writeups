#!/usr/bin/env python3
import struct
with open("bro.cimg", "wb") as bro:
    bro.write(b"<NMg")
    bro.write(struct.pack("<I", 1))
    bro.write(struct.pack("<I", 46))
    bro.write(b"\x00\x00\x00\x00")
    bro.write(b"\x14")
    bro.write(b"\x00" * 920)

